# Vaultrise backend configuration. Copy to .env and fill in.
# Optional vars degrade gracefully: no REDIS_URL => in-memory cache;
# no JUPITER_API_KEY => liquidation collateral sale is simulated (devnet has no
# Jupiter liquidity anyway).

PORT=4000
CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com

# Optional explicit overrides; otherwise read from ../contract/deployments/<cluster>.json
PROGRAM_ID=
USDC_MINT=
VRISE_MINT=

PUMPSWAP_PROGRAM_ID=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA

# Service keypairs. Each accepts EITHER a base58 secret key (recommended for
# Railway/hosting — set it as a secret env var, no .json committed) OR a path to
# a wallets/ json file (local dev; never ~/.config/solana).
# ADMIN_KEYPAIR is only needed for the local admin scripts (add-token, etc.) —
# the running service does NOT need it, so don't put it on the host.
ORACLE_UPDATER_KEYPAIR=../wallets/devnet/oracle-updater.json   # or: <base58 secret>
LIQUIDATOR_KEYPAIR=../wallets/devnet/liquidator.json           # or: <base58 secret>
ADMIN_KEYPAIR=../wallets/devnet/admin.json                     # or: <base58 secret> (only admin scripts use it)

# Cron cadences (seconds)
TWAP_INTERVAL_SECONDS=300
# Set false to stop the oracle aggregator (e.g. manual price for liquidation tests)
TWAP_ENABLED=true
LIQUIDATION_INTERVAL_SECONDS=300
LP_CHECK_INTERVAL_SECONDS=600

# Token eligibility thresholds (USD). Lower for mainnet/devnet testing with a
# small pool. TWAP_MIN_LP_USD must be <= MIN_LP_USD or eligible tokens get no
# fresh oracle price. Defaults: 50000 / 10000.
MIN_LP_USD=50000
TWAP_MIN_LP_USD=10000

# PostgreSQL (Prisma). Empty => in-memory storage (liquidation feed resets on
# restart). After setting it, run `npm run db:push` once to create the tables.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/vaultrise?schema=public

# Optional integrations
REDIS_URL=
JUPITER_API_URL=https://api.jup.ag/swap/v2
JUPITER_API_KEY=

# Comma-separated list of allowed CORS origins (default: *)
CORS_ORIGINS=
