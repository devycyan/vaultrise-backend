{
  "name": "vaultrise-backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Vaultrise off-chain services: public API, TWAP oracle, liquidation bot, LP monitor, alerts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc && mkdir -p dist/vaultrise/idl && cp src/vaultrise/idl/vaultrise.json dist/vaultrise/idl/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "add-token": "tsx scripts/add-token.ts",
    "update-token": "tsx scripts/update-token.ts",
    "set-price": "tsx scripts/set-price.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@prisma/client": "^6.19.3",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.19.3",
    "tsx": "^4.19.1",
    "typescript": "^5.7.3"
  }
}
